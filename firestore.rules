    match /notifications/{id} {
      allow write: if userIsAdmin(request.auth.token.phone_number);
      allow create: if userIsAdmin(request.auth.token.phone_number);
      // allow read: if userIsNotification(request.auth.token.phone_number);
      allow read: if request.auth != null;

    }
    
    match /mutuals/{id} {
      allow write, read: if userIsField(request.auth.token.phone_number);
    }
    
    match /mutualsUploader/{id} {
