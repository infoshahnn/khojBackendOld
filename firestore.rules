    //randomMutualsForInterestedIn
    match /randomMutualsForInterestedIn/{id} {
    	allow write: if request.auth != null;
      allow read: if userIsField(request.auth.token.phone_number);
    }

    match /testCollectionCompanies/{id} {
      allow read, write: if userIsSuper(request.auth.token.phone_number);
    }
    
    match /ad/{id} {
    	allow read: if request.auth != null;
      allow update: if false; //userIsSuper(request.auth.token.phone_number);
    }
    
    match /pincodes/{id} {
      allow write: if userIsSuper(request.auth.token.phone_number);
