rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
  	// rahul:
    match /testRahul/{id} {
    	allow read, write: if true;//userIsAdmin(request.auth.token.phone_number);
    }
    
    // aditya:
    match /testAditya/{id} {
    	allow read, write: if true;//userIsAdmin(request.auth.token.phone_number);
    }
    
    // saquib:
    match /testSaquib/{id} {
    	allow read, write: if true;//userIsAdmin(request.auth.token.phone_number);
    }
    
    // subscriptions:
    match /subscriptionsFrontEnd/{id} {
    	allow read, write: if true;//userIsAdmin(request.auth.token.phone_number);
    }
    
    match /subscriptionsBackEnd/{id} {
    	allow read, write: if true;//userIsAdmin(request.auth.token.phone_number);
    }
    
    match /subscriptionsCurrentState/{id} {
    	allow read, write: if true;//userIsAdmin(request.auth.token.phone_number);
    }
    
    match /random/plans {
    	allow read, write: if true;//userIsAdmin(request.auth.token.phone_number);
    }
  
  	match /testing/{id} {
    	// allow write, read, delete: 
    	// if resource.data.editable == true;
      
      allow write, read: if request.auth != null;

      
      // allow write, read, delete: if request.resource.data.name == 'hello';
      // 
      	//if true; 
      	//if request.auth != null && userIsSuper(request.auth.token.phone_number);
      
    } 
  
  	// match /{allPaths=**}/comments/{commentId} {
    //   allow read, create, update: if request.auth != null;
    //   allow delete: if request.auth != null 
    // }
    //premiumGooglePurchases
    
    match /premiumGooglePurchases/{id} {
    	allow create: if true;
    	allow read, write: if userIsAdmin(request.auth.token.phone_number);
    }
    
    match /experimentRatesPageV3/{id} {
    	allow create, update: if request.auth != null;
      allow write, read: if userIsAdmin(request.auth.token.phone_number);
    }
    
    match /weather/{id} {
    	allow read, write: if userIsAdmin(request.auth.token.phone_number);
    }
    
   	match /payments/{id} {
    	allow create: if true;
    	allow read, write: if userIsAdmin(request.auth.token.phone_number);
    }
    
   	match /ratesDetectorV5/{id} {
    	allow read, write: if userIsAdmin(request.auth.token.phone_number);
    }
    
    match /ratesDetector/{id} {
    	allow read, write: if userIsAdmin(request.auth.token.phone_number);
    }
    
    match /termsAgreed/{id} {
    	allow create: if true;
    	allow read, write: if userIsAdmin(request.auth.token.phone_number);
    }
    
    match /numbersNames/{id} {
    	allow read, write: if userIsAdmin(request.auth.token.phone_number);
    }
    
    match /premiumActions/{id} {
      allow create: if true;
    	allow read, write: if userIsAdmin(request.auth.token.phone_number);
    }
    
    match /wallPosts/{id} {
    	allow read, update: if request.auth != null;
    	allow create: if 
      	request.auth != null
        // && request.auth.uid == request.resource.data.wallPostCreatorUserId
        ;
      allow delete: if 
      	request.auth != null
      	// && (request.auth.uid == request.data.wallPostCreatorUserId 
        // ||	userIsField(request.auth.token.phone_number))
        ;
      
        match /comments/{commentId} {
        	allow read, create, update: if request.auth != null;
        	allow delete: if request.auth != null;
     	 	}
    }
    
    match /ronil/{id} {
    	allow write, read: if request.auth != null;
    	// allow create: if request.auth != null;
    	// allow delete: if userIsAdmin(request.auth.token.phone_number);
    }
    
    match /leads/{id} {
    	allow read, update: if request.auth != null;
    	allow create: if request.auth != null;
    	allow delete: if userIsAdmin(request.auth.token.phone_number);
    }
    
    match /usersKnowing/{id} {
    	allow write, read: if userIsAdmin(request.auth.token.phone_number);
    }
    
    match /shorts/{id} {
    	allow read, update: if request.auth != null;
    	allow create: if request.auth != null;
    	allow delete: if userIsAdmin(request.auth.token.phone_number);
      // allow delete: if 
      // 	request.auth != null;
    }
    
    match /auctions/{id} {
    	allow read, update: if request.auth != null;
    	allow create: if 
      	request.auth != null
        // && request.auth.uid == request.resource.data.wallPostCreatorUserId
        ;
      allow delete: if request.auth != null && userIsAdmin(request.auth.token.phone_number);
      
        match /bids/{commentId} {
        	allow read, create, update: if request.auth != null;
        	allow delete: if request.auth != null && (
          	resource.data.auctionCompanyId == 'psY1o2JxNta2ZdKn5XVu' ||
            resource.data.auctionCompanyId == 'rOm4LPLa1r7OsvXo9svd' ||
            resource.data.auctionCompanyId == 'vFUshf9BthJlMAjdLZ9w'
          );
     	 	}
    }
    
    match /testUsersAutoGenerated/{id} {
    	allow read: if true;
    	allow write, delete: if request.auth != null && userIsAdmin(request.auth.token.phone_number);
    }
    
    match /auctionApprovals/{approvalDocId}/applicantStatus/{applicationStatusDocId} {
    	allow read, write: if request.auth != null      
    }
    
    match /auctionApprovals/{approvalDocId}/auctionTriggers/{auctionTriggersDocId} {
    	allow read, write: if request.auth != null      
    }
    
    match /auctionApprovals/{id} {
    	allow read, write: if request.auth != null;
    	// allow write: if 
    	// request.auth.uid == request.resource.data.id 
    	// ||	userIsField(request.auth.token.phone_number)
    	// ;
      
	    allow delete: if request.auth != null && userIsAdmin(request.auth.token.phone_number);

      
      // allow delete: if false
      	// request.auth != null
      	// && (request.auth.uid == request.data.wallPostCreatorUserId 
        // ||	userIsField(request.auth.token.phone_number))
        // ;
    }
    
    match /auctionTriggers/{id} {
    	allow read, write: if userIsAdmin(request.auth.token.phone_number);
    }
    
    match /auctionApplications/{id} {
    	allow read, update, create: if request.auth != null;
      allow delete: if request.auth != null && userIsAdmin(request.auth.token.phone_number);
    }
    
  	match /auctionApplications/{id}/mutuals/{idOfMutualsWith} {
    	allow read, update, create: if request.auth != null;
      allow delete: if request.auth != null && userIsAdmin(request.auth.token.phone_number);
    }
    
    match /auctionBrokerApprovals/{id} {
    	allow read, update, create: if request.auth != null;
      allow delete: if request.auth != null && userIsAdmin(request.auth.token.phone_number);
    }
    
    match /auctionApprovals/{id}/brokerResponses/{brId} {
    	allow read, update, create: if request.auth != null;
      allow delete: if request.auth != null && userIsAdmin(request.auth.token.phone_number);
    }
    
    
    match /auctionApprovals/{id}/auctionMutuals/{aucMuId} {
    	allow read: if request.auth != null;
      allow delete: if false;
    }
    
    match /companyContactsForAdmins/{id} {
    	allow write, read: if request.auth != null && userIsSuper(request.auth.token.phone_number);
    }
    
    
    match /createConnections/{id} {
    	allow write, read, delete: if request.auth != null && userIsSuper(request.auth.token.phone_number);
    }
    
    match /test/{id} {
    	allow write, read, delete: if request.auth != null && userIsField(request.auth.token.phone_number);
    }
   
  	// users collection
  	match /testCollectionUsers/{id} {
    	allow create: if true;
      
      allow read: if request.auth != null;
      
      // allow read:  if request.auth.uid == id 
      // 	|| userIsField(request.auth.token.phone_number);   
      
      allow update: if request.auth.uid == id 
      	|| userIsAdmin(request.auth.token.phone_number)
        || (userIsField(request.auth.token.phone_number)
              && request
              		.resource.data.diff(resource.data).affectedKeys()
                  .hasOnly(['companyIdArray', 'name']));
                  
      allow delete: if (request.auth.uid == id);
    }
    
    match /companiesV2/{id} {
    	allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if userIsField(request.auth.token.phone_number);
      // allow update: if userIsAdmin(request.auth.token.phone_number)
      // 	|| (userIsField(request.auth.token.phone_number)
      //     	&& request.auth.token.phone_number in resource.data.fieldPhones)
      //   || request.auth.token.phone_number in resource.data.adminPhones;
      allow delete: if 
      	userIsSuper(request.auth.token.phone_number) || 
      	request.auth.token.phone_number == '+918799951361' ||
        request.auth.token.phone_number == '+918799951362';
    }
    
  	match /transporters/{id} {
      allow read, create, update: if userIsField(request.auth.token.phone_number);
    }
    
    match /allUsers/{id} {
      allow read, create, update: if userIsAdmin(request.auth.token.phone_number);
    }  
    
    match /newUsersV2/{id} {
    	allow read: if userIsField(request.auth.token.phone_number);
      allow write: if true;//userIsSuper(request.auth.token.phone_number);
    }
    
    match /brokers/{id} {
      allow read, write: if userIsSuper(request.auth.token.phone_number);
    }
    
    match /allContacts/{id} {
      allow read, create, update: if userIsField(request.auth.token.phone_number);
      allow delete: if userIsSuper(request.auth.token.phone_number);
    }
    
    match /allContactsV2/{id} {
      allow read, create, update: if userIsField(request.auth.token.phone_number);
      allow delete: if userIsSuper(request.auth.token.phone_number);
    }
    
    match /allContactsV2Uploader/{id} {
      allow read, create, update: if userIsField(request.auth.token.phone_number);
    }
    
    match /transporterPosts/{id} {
      allow read: if request.auth != null;
      allow write: if userIsField(request.auth.token.phone_number);
      
    }
    
    match /buySell/{id} {
      allow read: if request.auth != null;
      allow write: if userIsField(request.auth.token.phone_number);
    }
    
    match /callHistory/{id} {
      allow read, write: if userIsField(request.auth.token.phone_number);
    }
    
    match /mutualsEstablishFor/{id} {
    	allow read, write: if userIsField(request.auth.token.phone_number);
    }
    
    
    match /government/{id} {
      allow read: if true;
      allow create, update: if userIsField(request.auth.token.phone_number);
      allow delete: if userIsAdmin(request.auth.token.phone_number);
    }
    
    match /events/{id} {
      allow read: if true;
      allow create, update: if userIsField(request.auth.token.phone_number);
      allow delete: if userIsAdmin(request.auth.token.phone_number);
    }
    
    match /deleteNetwork/{id} {
      allow read, write: if userIsSuper(request.auth.token.phone_number);
    }
    
    match /deleteNetworkUploader/{id} {
      allow read, write: if userIsField(request.auth.token.phone_number);
    }
    
    match /warehouses/{id} {
      allow read, update: if true;// if userIsField(request.auth.token.phone_number);
    }
    
    match /deletedUsers/{id} {
      allow write: if true;
      allow read: if userIsField(request.auth.token.phone_number);
    }   

	 	// match /{allPaths=**}/userInfo/{userInfoId} {
	 	// allow read: if userIsAdmin(request.auth.token.phone_number);
	 	// allow update: if userIsSuper(request.auth.token.phone_number);
	 	// } 
    
	 	match /testCollectionUsers/{id}/userInfo/{userInfoId} {
      allow create: if true;

      allow read: if request.auth.uid == id
      	|| userIsField(request.auth.token.phone_number);   

      allow update: if request.auth.uid == id
      	|| userIsField(request.auth.token.phone_number)
        // || request.auth.token.phone_number == '+918799951362'
        ;
        
      allow delete: if false; // userIsSuper(request.auth.token.phone_number);
	 	}
    
    match /{allPaths=**}/userInfo/{userInfoId} {
    	allow create: if true;
      allow read: if userIsField(request.auth.token.phone_number);   
      allow update: if userIsSuper(request.auth.token.phone_number); 
      allow delete: if false; // userIsSuper(request.auth.token.phone_number);
    }
    
    match /testCollectionUsers/{id}/grain/{docId} {
      allow read, write: if userIsSuper(request.auth.token.phone_number);
    }
    match /testCollectionUsers/{id}/warehouse/{docId} {
      allow read, write: if userIsSuper(request.auth.token.phone_number);
