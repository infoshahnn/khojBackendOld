    match /searchHistorySummary2KeywordWise/{id} {
      allow write: if userIsSuper(request.auth.token.phone_number);
    	allow read: if userIsAdmin(request.auth.token.phone_number);
    }
    
    match /display/withoutContacts {
    	allow read: if true;
      allow write: if userIsField(request.auth.token.phone_number);
    }
    
    match /display/{id} {
    	allow read: if request.auth != null;
